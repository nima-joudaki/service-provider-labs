interface Loopback0
 ip address 192.168.100.4 255.255.255.255
 ip ospf 100 area 0
!
interface GigabitEthernet0/0
 ip address 10.4.5.4 255.255.255.0
 mpls bgp forwarding
!
interface GigabitEthernet0/1
 ip address 10.3.4.4 255.255.255.0
 ip ospf 100 area 0
!
router ospf 100
 mpls ldp autoconfig
!
router bgp 65100
 bgp log-neighbor-changes
 no bgp default route-target filter
 neighbor 10.4.5.5 remote-as 65200
 neighbor 192.168.100.2 remote-as 65100
 neighbor 192.168.100.2 update-source Loopback0
 !
 address-family vpnv4
  neighbor 10.4.5.5 activate
  neighbor 10.4.5.5 send-community extended
  neighbor 192.168.100.2 activate
  neighbor 192.168.100.2 send-community extended
  neighbor 192.168.100.2 next-hop-self
 exit-address-family
