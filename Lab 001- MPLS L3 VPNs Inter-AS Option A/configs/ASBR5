ip vrf VPN-A
 rd 200:8
 route-target export 200:8
 route-target import 200:8
!
ip vrf VPN-B
 rd 200:10
 route-target export 200:10
 route-target import 200:10
!
interface Loopback0
 ip address 192.168.200.5 255.255.255.255
 ip ospf 200 area 0
!
interface GigabitEthernet0/1
 ip address 10.5.6.5 255.255.255.0
 ip ospf 200 area 0
!
interface GigabitEthernet0/0.45
 encapsulation dot1Q 45
 ip vrf forwarding VPN-A
 ip address 10.4.5.5 255.255.255.0
!
interface GigabitEthernet0/0.54
 encapsulation dot1Q 54
 ip vrf forwarding VPN-B
 ip address 10.5.4.5 255.255.255.0
!
router ospf 200
 mpls ldp autoconfig
!
router bgp 65200
 bgp log-neighbor-changes
 neighbor 192.168.200.7 remote-as 65200
 neighbor 192.168.200.7 update-source Loopback0
 !
 address-family vpnv4
  neighbor 192.168.200.7 activate
  neighbor 192.168.200.7 send-community extended
 exit-address-family
 !
 address-family ipv4 vrf VPN-A
  redistribute static
  neighbor 10.4.5.4 remote-as 65100
  neighbor 10.4.5.4 activate
 exit-address-family
 !
 address-family ipv4 vrf VPN-B
  redistribute static
  neighbor 10.5.4.4 remote-as 65100
  neighbor 10.5.4.4 activate
 exit-address-family
!         
