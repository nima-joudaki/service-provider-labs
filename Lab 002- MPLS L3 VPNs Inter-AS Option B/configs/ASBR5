interface Loopback0
 ip address 192.168.200.5 255.255.255.255
 ip ospf 200 area 0
!
interface GigabitEthernet0/0
 ip address 10.4.5.5 255.255.255.0
 mpls bgp forwarding
!
interface GigabitEthernet0/1
 ip address 10.5.6.5 255.255.255.0
 ip ospf 200 area 0
!
router ospf 200
 mpls ldp autoconfig
!
router bgp 65200
 bgp log-neighbor-changes
 no bgp default route-target filter
 neighbor 10.4.5.4 remote-as 65100
 neighbor 192.168.200.7 remote-as 65200
 neighbor 192.168.200.7 update-source Loopback0
 !
 address-family vpnv4
  neighbor 10.4.5.4 activate
  neighbor 10.4.5.4 send-community extended
  neighbor 192.168.200.7 activate
  neighbor 192.168.200.7 send-community extended
  neighbor 192.168.200.7 next-hop-self
 exit-address-family
