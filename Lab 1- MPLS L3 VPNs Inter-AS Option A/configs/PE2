PE2:

ip vrf VPN-A
 rd 100:1
 route-target export 100:1
 route-target import 100:1
!
ip vrf VPN-B
 rd 100:9
 route-target export 100:9
 route-target import 100:9
!
interface Loopback0
 ip address 192.168.100.2 255.255.255.255
 ip ospf 100 area 0
!
interface GigabitEthernet0/0
 ip address 10.2.3.2 255.255.255.0
 ip ospf 100 area 0
!
interface GigabitEthernet0/1
 ip vrf forwarding VPN-A
 ip address 10.1.2.2 255.255.255.0
!         
interface GigabitEthernet0/2
 ip vrf forwarding VPN-B
 ip address 10.2.9.2 255.255.255.0
!
router ospf 100
 mpls ldp autoconfig
!
router bgp 65100
 bgp log-neighbor-changes
 neighbor 192.168.100.4 remote-as 65100
 neighbor 192.168.100.4 update-source Loopback0
 !
 address-family vpnv4
  neighbor 192.168.100.4 activate
  neighbor 192.168.100.4 send-community extended
 exit-address-family
 !
 address-family ipv4 vrf VPN-A
  redistribute static
 exit-address-family
 !
 address-family ipv4 vrf VPN-B
  redistribute static
 exit-address-family
!
ip route vrf VPN-A 192.168.1.0 255.255.255.0 10.1.2.1
ip route vrf VPN-B 192.168.9.0 255.255.255.0 10.2.9.9
